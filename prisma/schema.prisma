generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("EMPLOYEE")
  department    String   @default("General")
  managerId     String?
  manager       User?    @relation("ManagerEmployee", fields: [managerId], references: [id])
  employees     User[]   @relation("ManagerEmployee")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  goals         Goal[]
  checkIns      CheckIn[]
  auditLogs     AuditLog[]
  notifications Notification[]
}

model GoalCycle {
  id        String   @id @default(uuid())
  name      String
  year      Int
  startDate DateTime
  endDate   DateTime
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  goals     Goal[]
}

model Goal {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  cycleId       String
  cycle         GoalCycle @relation(fields: [cycleId], references: [id])
  thrustArea    String
  title         String
  description   String   @default("")
  uomType       String
  target        String
  weightage     Float
  status        String   @default("DRAFT")
  isShared      Boolean  @default(false)
  sharedFromId  String?
  sharedFrom    Goal?    @relation("SharedGoals", fields: [sharedFromId], references: [id])
  sharedCopies  Goal[]   @relation("SharedGoals")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  achievements  Achievement[]
  checkIns      CheckIn[]
  auditLogs     AuditLog[]
}

model Achievement {
  id                String   @id @default(uuid())
  goalId            String
  goal              Goal     @relation(fields: [goalId], references: [id])
  quarter           String
  actualAchievement String   @default("")
  progressStatus    String   @default("NOT_STARTED")
  score             Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([goalId, quarter])
}

model CheckIn {
  id             String   @id @default(uuid())
  goalId         String
  goal           Goal     @relation(fields: [goalId], references: [id])
  quarter        String
  managerId      String
  manager        User     @relation(fields: [managerId], references: [id])
  comment        String   @default("")
  checkedAt      DateTime @default(now())

  @@unique([goalId, quarter])
}

model AuditLog {
  id        String   @id @default(uuid())
  goalId    String?
  goal      Goal?    @relation(fields: [goalId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  field     String   @default("")
  oldValue  String   @default("")
  newValue  String   @default("")
  timestamp DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EscalationRule {
  id             String @id @default(uuid())
  name           String
  condition      String
  daysThreshold  Int
  notifyRole     String
  isActive       Boolean @default(true)
}
